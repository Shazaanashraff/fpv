# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Shopify Configuration
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_API_VERSION=2024-01

# Option 1: Static Admin API Access Token (from Shopify Admin → Develop apps)
# Use this if you have a custom app with a non-expiring token
SHOPIFY_ADMIN_API_ACCESS_TOKEN=your_shopify_admin_api_access_token

# Option 2: OAuth Client Credentials (auto-refresh tokens)
# Use this for automatic token refresh every 24 hours
# Leave blank if using Option 1
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# OTP Configuration
OTP_COOLDOWN_SECONDS=60
OTP_VERIFICATION_TTL_SECONDS=600
