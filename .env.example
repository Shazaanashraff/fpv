# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration - Allowed origins (comma-separated, or * for all)
# For production, set to your Shopify store URL(s)
CORS_ORIGINS=https://your-store.com,https://your-store.myshopify.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Shopify Configuration
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=your_shopify_admin_api_access_token
SHOPIFY_API_VERSION=2024-01

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# OTP Configuration
OTP_COOLDOWN_SECONDS=60
OTP_VERIFICATION_TTL_SECONDS=600
